# ─── Variables de entorno para Vinilos Store Backend ──────────
# Copia este archivo como .env y ajusta los valores

# ─── Base de datos ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vinilos_db
DB_USER=vinilos_user
DB_PASSWORD=tu_password_seguro_aqui
DB_ROOT_PASSWORD=tu_root_password_aqui

# ─── JWT ──────────────────────────────────────────────────────
# Genera una clave segura: openssl rand -base64 64
JWT_SECRET=CambiaEsteSecretoPorUnoMuyLargoYSeguroEnProduccion2024
JWT_EXPIRATION=86400000

# ─── CORS ─────────────────────────────────────────────────────
# Orígenes del frontend React (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Google OAuth2 ────────────────────────────────────────────
# Obtén estas credenciales en: https://console.cloud.google.com/
# 1. Crea un proyecto → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (tipo: Web application)
# 3. Authorized redirect URIs: http://localhost:5173
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# ─── Servidor ─────────────────────────────────────────────────
PORT=8080
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod
